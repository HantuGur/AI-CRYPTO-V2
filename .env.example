# ─── LiteLLM ────────────────────────────────────────────────────────────────
# Your LiteLLM base URL (OpenAI-compatible)
LITELLM_BASE_URL=https://your-litellm-endpoint/v1

# API key for your LiteLLM deployment
LITELLM_API_KEY=

# Model name as registered in your LiteLLM config
# Default: claude-sonnet-4-6
LITELLM_MODEL=claude-sonnet-4-6

# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Supabase: Project Settings → Database → URI
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Pipeline mode ───────────────────────────────────────────────────────────
# Set to "true" to skip real LLM calls and return mock report data.
# Useful for UI development without needing a live API key.
USE_MOCK_PIPELINE=true
