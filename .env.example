# ─── LiteLLM ────────────────────────────────────────────────────────────────
# Your LiteLLM base URL (OpenAI-compatible)
LITELLM_BASE_URL=https://litellm.koboi2026.biz.id/v1

# API key for your LiteLLM deployment
LITELLM_API_KEY=sk-JSyP6Guu2s8_QAtHayJ26A

# Model name as registered in your LiteLLM config
# Default: Chatgpt-5.2
LITELLM_MODEL=Chatgpt-5.2

# ─── Pipeline mode ───────────────────────────────────────────────────────────
# Set to "true" to skip real LLM calls and return mock report data.
# Useful for UI development without needing a live API key.
USE_MOCK_PIPELINE=false
